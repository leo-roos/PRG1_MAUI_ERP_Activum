<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PRG1_MAUI_ERP_Activum.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:PRG1_MAUI_ERP_Activum.View"
    Shell.NavBarIsVisible="False">

    <Shell.FlyoutContent>
        <local:CustomFlyoutView x:Name="FlyoutView" />
    </Shell.FlyoutContent>

    <ShellContent Route="LoginPage" ContentTemplate="{DataTemplate local:LoginPage}" />

    <ShellContent Route="NewCustomerPage" ContentTemplate="{DataTemplate local:NewCustomerPage}" />
    <ShellContent Route="SelectedCustomerPage" ContentTemplate="{DataTemplate local:SelectedCustomerPage}" />
    <ShellContent Route="SelectedCustomerInsurancePage" ContentTemplate="{DataTemplate local:SelectedCustomerInsurancePage}" />
    <ShellContent Route="SelectedCustomerNotesPage" ContentTemplate="{DataTemplate local:SelectedCustomerNotesPage}" />
    <ShellContent Route="SelectedCustomerInformationPage" ContentTemplate="{DataTemplate local:SelectedCustomerInformationPage}" />

    <ShellContent Route="SelectedInsurancePage" ContentTemplate="{DataTemplate local:SelectedInsurancePage}" />
    <ShellContent Route="NewInsurancePage" ContentTemplate="{DataTemplate local:NewInsurancePage}" />

    <ShellContent Route="MainPage" ContentTemplate="{DataTemplate local:MainPage}" />
    <ShellContent Route="CustomersPage" ContentTemplate="{DataTemplate local:CustomersPage}" />
    <ShellContent Route="InsurancePage" ContentTemplate="{DataTemplate local:InsurancePage}" />
    <ShellContent Route="ToolsPage" ContentTemplate="{DataTemplate local:ToolsPage}" />
    <ShellContent Route="SupportPage" ContentTemplate="{DataTemplate local:SupportPage}" />

    <ShellContent Route="CalculatorPage" ContentTemplate="{DataTemplate local:CalculatorPage}" />
    <ShellContent Route="SalaryPage" ContentTemplate="{DataTemplate local:SalaryPage}" />
    <ShellContent Route="PerDiemPage" ContentTemplate="{DataTemplate local:PerDiemPage}" />
    <ShellContent Route="AboutPage" ContentTemplate="{DataTemplate local:AboutPage}" />
</Shell>