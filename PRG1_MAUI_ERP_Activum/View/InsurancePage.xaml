<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PRG1_MAUI_ERP_Activum.View.InsurancePage"
             Title="Försäkringar"
             Style="{StaticResource Key=BasePageStyle}">
    <VerticalStackLayout Padding="10">
        <Label
            Padding="10"
            Text="Försäkringar"
            Style="{StaticResource Headline}"
            SemanticProperties.HeadingLevel="Level1"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />

        <Label Text="Försäkringar för vald kund" FontAttributes="Bold" Margin="0,30,0,10" />

        <Grid RowDefinitions="*, Auto" RowSpacing="10" ColumnDefinitions="1*,1*,1*">
            <Label Text="Typ" Grid.Column="0" FontAttributes="Bold" />
            <Label Text="Kostnad" Grid.Column="1" FontAttributes="Bold" />
            <Label Text="Aktiv" Grid.Column="2" FontAttributes="Bold" />

            <Border Grid.Row="1" Grid.ColumnSpan="3"></Border>
        </Grid>

        <CollectionView x:Name="CustomerInsurances" SelectionMode="Single" SelectionChanged="CustomerInsurances_SelectionChanged">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="1*,1*,1*" Padding="5">
                        <Label Text="{Binding Type}" Grid.Column="0" Padding="5, 0, 0, 0" />
                        <Label Text="{Binding MonthlyCost, StringFormat='{0} kr / månad'}" Grid.Column="1" />
                        <Label Text="{Binding StartDate}" Grid.Column="2" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid RowDefinitions="Auto, Auto" RowSpacing="10" ColumnDefinitions="3*, 1*" Margin="0, 30, 0, 0">
            <Label Grid.ColumnSpan="2" Style="{StaticResource Key=SubHeadline}" Text="Lägg till ny Försäkring" />
            
            <Picker x:Name="InsurancesPicker" Grid.Row="1" Grid.Column="0" />
            <Button Grid.Row="1" Grid.Column="1" Text="Lägg Till" Clicked="Button_Clicked_1" />
        </Grid>
    </VerticalStackLayout>
</ContentPage>