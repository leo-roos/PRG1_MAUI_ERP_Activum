<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PRG1_MAUI_ERP_Activum.View.InsurancePage"
             Title="Försäkringar"
             Style="{StaticResource Key=BasePageStyle}">
    <VerticalStackLayout Padding="10">
        <Label
            Padding="10"
            Text="Försäkringar"
            Style="{StaticResource Headline}"
            SemanticProperties.HeadingLevel="Level1"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />

      

        <CollectionView
            x:Name="CustomerInsurances"
            SelectionChanged="CustomerInsurances_SelectionChanged"
            SelectionMode="Single">
            <CollectionView.Header>
                <Grid RowDefinitions="*, Auto" RowSpacing="5" ColumnDefinitions="2*,1*" Padding="5">
                    <Label Text="Typ" FontAttributes="Bold" Grid.Column="0" />
                    <Label Text="Kostnad" FontAttributes="Bold" Grid.Column="1" HorizontalTextAlignment="End"/>
                    
                   

                    <Border Grid.Row="1" Grid.ColumnSpan="4"></Border>
                </Grid>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="2*,1*" Padding="5">
                        <Label Text="{Binding Type}" Grid.Column="0" Padding="5, 0, 0, 0" />
                        <Label Text="{Binding MonthlyCost, StringFormat='{0} kr / månad'}" Grid.Column="1" HorizontalTextAlignment="End"/>
                     
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Margin="0, 30, 0 ,0"
              RowDefinitions="Auto, Auto, Auto" RowSpacing="10"
              ColumnDefinitions="Auto, *" ColumnSpacing="5">

            
        </Grid>

        <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto" RowSpacing="10" ColumnDefinitions="1*, 5*" Margin="0, 0, 0, 0">
            <Label Grid.ColumnSpan="2" Style="{StaticResource Key=SubHeadline}" Text="Skapa ny Försäkring" />
            
            <Entry x:Name="TypeInsurancesEntry" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"/>
            <Label Text="Typ" Grid.Row="1" Grid.Column="0" FontAttributes="Bold"/>
            <Button Grid.Row="5" Grid.Column="0" Text="Lägg Till" Clicked="Button_Clicked_1" Grid.ColumnSpan="2"/>
            <Entry x:Name="PriceInsurancesEntry" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"/>
            <Label Text="Kostnad" Grid.Row="3" Grid.Column="0" FontAttributes="Bold"/>


        </Grid>
    </VerticalStackLayout>
</ContentPage>