<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PRG1_MAUI_ERP_Activum.View.SelectedCustomerInsurancePage"
             Title="Vald Försäkring"
             Style="{StaticResource Key=BasePageStyle}">
    <ScrollView>
        <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, *, Auto" RowSpacing="10" Padding="10">
            <Label
                x:Name="Title"
                Grid.Row="0"
                Padding="10"
                Text="Vald Försärking"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1"
                VerticalOptions="Center" 
                HorizontalOptions="Center" />

            <Label Grid.Row="1" Text="Försäkringsdetaljer" FontAttributes="Bold" Margin="0,30,0,10" />

            <Label Grid.Row="2" Text="Typ" FontAttributes="Bold" />
            <Entry Grid.Row="3" x:Name="TypeEntry" Style="{StaticResource Key=ReadOnlyEntryStyle}" IsReadOnly="True" />

            <Label Grid.Row="4" Text="Pris (kr/månad)" FontAttributes="Bold" />
            <Entry Grid.Row="5" x:Name="CostEntry" Placeholder="500" />

            <Label Grid.Row="6" Text="Start Datum" FontAttributes="Bold" />
            <DatePicker Grid.Row="7" x:Name="StartDatePicker" />

            <Label Grid.Row="8" Text="Slut Datum" FontAttributes="Bold" />
            <DatePicker Grid.Row="9" x:Name="EndDatePicker" />

            <Button Grid.Row="10" Text="Spara" Clicked="Save_Clicked" />

            <Button Clicked="GoBack_Clicked" Grid.Row="12" Text="Gå Tillbaka" />
        </Grid>
    </ScrollView>
</ContentPage>