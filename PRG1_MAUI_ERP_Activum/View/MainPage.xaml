<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             x:Class="PRG1_MAUI_ERP_Activum.View.MainPage"
             Title="Start"
             Style="{StaticResource Key=BasePageStyle}">

    <ScrollView>
        <Grid Padding="20"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
              ColumnDefinitions="*"
              RowSpacing="10">

            <Image Source="{AppThemeBinding Light='logga_activum_svart.png', Dark='logga_activum_vit.png'}"
                   WidthRequest="200"
                   HeightRequest="100" />

            <Label Grid.Row="1"
                   Text="Sök efter kund"
                   FontAttributes="Bold" />

            <Entry x:Name="CustomerIdEntry"
                   Grid.Row="2"
                   Placeholder="förnamn, efternamn, email eller telefon"
                   ReturnType="Search"
                   TextChanged="CustomerIdEntry_TextChanged" />

            <CollectionView Grid.Row="3"
            x:Name="CustomersCollection"
            SelectionMode="Single"
            SelectionChanged="CustomersCollection_SelectionChanged">
                <CollectionView.Header>
                    <Grid RowDefinitions="*, Auto" RowSpacing="10" ColumnDefinitions="2*,2*,3*,2*" Padding="5">
                        <Label Text="Förnamn" FontAttributes="Bold" />
                        <Label Text="Efternamn" Grid.Column="1" FontAttributes="Bold" />
                        <Label Text="Email" Grid.Column="2" FontAttributes="Bold" />
                        <Label Text="Telefon" Grid.Column="3" FontAttributes="Bold" />

                        <Border Grid.Row="3" Grid.ColumnSpan="4"></Border>
                    </Grid>
                </CollectionView.Header>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="2*,2*,3*,2*" Padding="10">
                            <Label Text="{Binding FirstName}" Padding="5, 0, 0 ,0" />
                            <Label Text="{Binding LastName}" Grid.Column="1" />
                            <Label Text="{Binding Email}" Grid.Column="2" />
                            <Label Text="{Binding Phone}" Grid.Column="3" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <VerticalStackLayout Grid.Row="4" Spacing="10" IsVisible="False" x:Name="ChosenCustomerLayout">
                <Label Text="Försäkringar aktuell kund"
                    FontAttributes="Bold" />

                <CollectionView
                    x:Name="CustomerInsurances"
                    SelectionChanged="CustomerInsurances_SelectionChanged"
                    SelectionMode="Single">
                    <CollectionView.Header>
                        <Grid RowDefinitions="*, Auto" RowSpacing="5" ColumnDefinitions="1*,1*,1*,1*" Padding="10">
                            <Label Text="Typ" FontAttributes="Bold" Grid.Column="0" />
                            <Label Text="Kostnad" FontAttributes="Bold" Grid.Column="1" />
                            <Label Text="Startdatum" FontAttributes="Bold" Grid.Column="2" />
                            <Label Text="Slutdatum" FontAttributes="Bold" Grid.Column="3" />

                            <Border Grid.Row="1" Grid.ColumnSpan="4"></Border>
                        </Grid>
                    </CollectionView.Header>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="1*,1*,1*,1*" Padding="10">
                                <Label Text="{Binding Type}" Grid.Column="0" Padding="5, 0, 0, 0" />
                                <Label Text="{Binding MonthlyCost, StringFormat='{0} kr / månad'}" Grid.Column="1" />
                                <Label Text="{Binding StartDate, StringFormat='{0:yyyy-MM-dd}'}" Grid.Column="2" />
                                <Label Text="{Binding EndDate, StringFormat='{0:yyyy-MM-dd}'}" Grid.Column="3" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <Label Grid.Row="5"
                   Text="Skadeståndsanmälan (anteckningar)"
                   FontAttributes="Bold" />

            <Editor x:Name="NotesEditor"
                    Grid.Row="6"
                    HeightRequest="160"
                    AutoSize="TextChanges" />

            <Label Grid.Row="7"
                   Text="Datum skadeanmälan mottogs"
                   FontAttributes="Bold" />

            <DatePicker x:Name="DatePickerField"
                        Grid.Row="8"
                        Date="{x:Static sys:DateTime.Today}" />            
            
            <Button Grid.Row="9"
                    Text="Spara anteckning"
                    Clicked="OnSaveNotesClicked" />

        </Grid>
    </ScrollView>

</ContentPage>
